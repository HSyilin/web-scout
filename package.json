{
  "name": "web-scout",
  "version": "1.0.0",
  "description": "可视化智能爬虫 - Web Scout",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "crawler",
    "scraper",
    "web-scout",
    "electron"
  ],
  "author": "Web Scout Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "jsdom": "^29.1.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "docx": "^9.7.1",
    "pdfkit": "^0.19.1",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.webscout.app",
    "productName": "Web Scout",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "assets/**/*"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
